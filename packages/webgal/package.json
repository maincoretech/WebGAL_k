    "@vitejs/plugin-react": "4",
    "eslint": "9",
    "eslint-config-alloy": "^4.5.1",
    "eslint-config-prettier": "9",
    "eslint-plugin-prettier": "5",
    "eslint-plugin-react": "^7.29.4",
    "lint-staged": "15",
    "prettier": "3",
    "rollup-plugin-visualizer": "5",
    "typescript": "^5.9.3",
    "unplugin-info": "^1.3.2",
    "vite": "5",
    "vite-plugin-compression": "^0.5.1"
  }
