{
  "name": "webgal-engine",
  "version": "4.6.1",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite --host --port 3000",
    "build": "bun scripts/update-engine-version.js && NODE_ENV=production bunx tsc && bunx --bun vite build --base=./ && rimraf dist/game",
    "preview": "bunx --bun vite preview",
    "lint": "eslint src/** --fix",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@emotion/css": "^11.11.2",
    "@reduxjs/toolkit": "1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "angular-expressions": "^1.5.5",
    "gifuct-js": "^2.1.2",
    "i18next": "22",
    "localforage": "^1.10.0",
    "modern-css-reset": "^1.4.0",
    "pixi-filters": "5",
    "pixi-live2d-display": "^0.5.0-beta",
    "pixi.js": "7",
    "popmotion": "^11.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "12",
    "react-redux": "8",
    "sass": "^1.101.0",
    "vite-plugin-package-version": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "20",
    "@types/react": "18",
    "@types/react-dom": "18",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
